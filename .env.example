# Database
DATABASE_URL="mysql://root:password@localhost:3306/ai_translator"

# JWT — must be at least 32 chars; generate with: openssl rand -base64 48
JWT_SECRET="change-this-to-a-random-64-char-string"

# DeepSeek API
DEEPSEEK_API_KEY="sk-your-api-key-here"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-flash"

# SMTP (configured via admin panel, these are fallbacks)
SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Redis
REDIS_URL="redis://localhost:6379"

# App
NEXT_PUBLIC_APP_URL="http://127.0.0.1:65108"
APP_NAME="CM Translator"
